# =============================================================================
# 使用方式：复制本文件为 .env，再按需修改。.env 已被 git 忽略，勿提交。
# - 本地开发：在项目根目录保留 .env，主要改「本地开发」段。
# - Docker 生产：把 .env 放在与 docker-compose.yml 同目录，主要改「Docker/生产」段。
# =============================================================================

# -----------------------------------------------------------------------------
# 本地开发（跑 backend/frontend 在本机时使用）
# -----------------------------------------------------------------------------
# 数据库连接串（生产用 Docker 时由 compose 用 POSTGRES_* 拼出，此处仅本地）
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/mgmt_web

# 上传文件目录（本地从项目根启动后端时用；Docker 内固定为 /app/uploads）
UPLOAD_DIR=./uploads

# 可选：前端地址，用于 CORS（本地开发可省略）
# FRONTEND_ORIGIN=http://localhost:3000

# 可选：登录 JWT 签名密钥（本地可用默认；生产务必改为强随机值）
# AUTH_SECRET=orient-g-auth-secret-change-in-production

# -----------------------------------------------------------------------------
# Docker / 生产部署（docker compose 会读取同目录 .env，只改下面即可）
# -----------------------------------------------------------------------------
# 数据库：用户名、密码、库名（compose 会据此拼 DATABASE_URL 给 backend）
POSTGRES_USER=mgmt
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mgmt_web

# 登录 JWT 签名密钥（生产务必改为强随机，如：openssl rand -hex 32）
AUTH_SECRET=orient-g-auth-secret-change-in-production

# 前端访问地址（用于 CORS、回调等，如 https://your-internal-domain）
FRONTEND_ORIGIN=http://localhost:3000

# Caddy 监听 IP：127.0.0.1 仅本机，0.0.0.0 所有网卡，或内网 IP 如 192.168.1.10
BIND_IP=127.0.0.1

# 可选：覆盖默认镜像（不改则用 ghcr.io 的 latest）
# BACKEND_IMAGE=ghcr.io/jairwye/orient-g-backend:latest
# FRONTEND_IMAGE=ghcr.io/jairwye/orient-g-frontend:latest
